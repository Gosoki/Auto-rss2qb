# 复制为 .env 后按需修改。.env 不应提交到版本库。

# ---- qBittorrent Web UI ----
QB_URL=http://127.0.0.1:8080
QB_USERNAME=your_qb_user
QB_PASSWORD=your_qb_password

# ---- 数据库 ----
# DB_TYPE=sqlite（默认，本地文件、自动建表、无需额外依赖）或 mysql
DB_TYPE=sqlite
# SQLITE_PATH 不填则默认放在脚本目录下的 autorss.db
# SQLITE_PATH=/path/to/autorss.db

# ---- MySQL（仅 DB_TYPE=mysql，或做数据迁移时才需要）----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=jp_autorss

# ---- 代理（OPEN_PROXY=true 时才生效）----
OPEN_PROXY=false
PROXY_URL=http://172.16.1.10:10811

# ---- 路径 ----
DOWN_PATH=/media/upan/Anime
LOG_PATH=log
TORRENT_PATH=torrent

# ---- 运行行为 ----
STOP_TIME=1200                 # 每轮抓取间隔（秒）
TRY_INSERT_ALL=false           # true=遍历全部条目避免漏番；false=遇到已存在即休眠
STARTUP_DOWNLOAD_LIMIT=100     # 启动时补下的最大条数
POLL_DOWNLOAD_LIMIT=10         # 每轮补下的最大条数

# ---- 通知（NOTIFY_URL 留空即关闭通知）----
NOTIFY_URL=http://192.168.123.1:32023/C2BOT/GROUP/971990897
NOTIFY_ENABLED=true
NOTIFY_DELAY=1
NOTIFY_TIMEOUT=10
NOTIFY_RETRIES=3
