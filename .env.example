# 复制为 .env 后按需填写。.env 不要提交。

# ---- qBittorrent ----
QB_URL=http://127.0.0.1:8080
QB_USERNAME=your_qb_user
QB_PASSWORD=your_qb_password

# ---- 路径 ----
DOWN_PATH=/media/upan/Anime
# DB_PATH 不填默认 data/autorss.db

# ---- 代理（OPEN_PROXY=true 才生效）----
OPEN_PROXY=false
PROXY_URL=http://127.0.0.1:10811

# ---- 轮询 ----
POLL_INTERVAL=1200

# ---- Web ----
WEB_PORT=8080

# ---- 源 ----
ANI_RSS_URL=https://nyaa.si/?page=rss&u=ANiTorrent

# ---- 通知（留空即关闭）----
NOTIFY_URL=
